# ===== Global ignore =====
node_modules/
.env
dist/
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== Frontend (Next.js) =====
frontend/.next/
frontend/out/
frontend/build
frontend/.vercel
frontend/coverage
frontend/.pnp
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/next-env.d.ts
frontend/*.tsbuildinfo
frontend/.env*
frontend/.next/

# ===== Backend (Express or Node.js) =====
backend/node_modules/
backend/dist/
backend/.env
.next/